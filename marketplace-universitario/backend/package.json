{
  "name": "marketplace-universitario-backend",
  "version": "1.0.0",
  "description": "Backend API for Marketplace de Emprendedores Universitarios",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "postinstall": "prisma generate",
    "dev": "kill-port 3001 && nodemon src/server.js",
    "test": "jest --coverage --forceExit",
    "test:watch": "jest --watch",
    "lint": "eslint src tests --ext .js",
    "lint:fix": "eslint src tests --ext .js --fix",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:seed": "node prisma/seed.js",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset --force"
  },
  "dependencies": {
    "@prisma/client": "^5.10.2",
    "@supabase/supabase-js": "^2.43.0",
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.13",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "kill-port": "^2.0.1",
    "nodemon": "^3.1.0",
    "prisma": "^5.10.2",
    "supertest": "^6.3.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
