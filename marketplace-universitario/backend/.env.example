NODE_ENV=production
PORT=3001

# PostgreSQL — Supabase connection pooler URL
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres?pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://USER:PASSWORD@HOST:5432/postgres

# JWT — genera con: node -e "require('crypto').randomBytes(48).toString('hex')"
JWT_SECRET=generate-a-secure-random-string-minimum-32-chars
JWT_EXPIRES_IN=8h

# Bcrypt
BCRYPT_COST_FACTOR=12

# SendGrid
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=tu-email@dominio.com

# Supabase Storage
SUPABASE_URL=https://TU-PROYECTO.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...

# CORS — URL del frontend en producción
FRONTEND_URL=https://tu-proyecto.vercel.app

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
